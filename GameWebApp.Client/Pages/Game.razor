@page "/"
@page "/game"
@using GameWebApp.Shared
@using Microsoft.AspNetCore.SignalR.Client
@implements IDisposable
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Puzzle Game</PageTitle>

<header class="game-top-header">
    <h1>Puzzle Game</h1>

    <div class="game-top-actions">
        <label class="sound-toggle">
            <input type="checkbox" @bind="isSoundOn" />
            Sound On
        </label>

        @if (IsGameStarted)
        {
            <button class="btn btn-outline-primary btn-sm" @onclick="ShowHowToPlay">
                How to Play
            </button>

            <button class="btn btn-outline-secondary btn-sm" @onclick="ResetGame" disabled="@isAnimatingMovement">
                Reset Game / New Game
            </button>
        }
    </div>
</header>

@if (!IsGameStarted)
{
    <section class="setup-panel">
        <div class="setup-grid">
            <div class="setup-left-column">
                <div class="welcome-card">
                    <span class="welcome-label">Local or Multiplayer</span>
                    <h2>Puzzle Game</h2>
                    <p class="welcome-subtitle">
                        A two-group quiz board game. Roll the dice, answer questions, and race to the finish tile.
                    </p>

                    <div class="welcome-highlights">
                        <span>Dice-first turns</span>
                        <span>Question timer</span>
                        <span>Finish tile 44</span>
                    </div>
                </div>

                <section class="instructions-panel">
                    <div class="setup-card-header">
                        <span class="status-label">Guide</span>
                        <h3>How to Play</h3>
                    </div>

                    <div class="instruction-columns">
                        <div>
                            <h4>Local Play</h4>
                            <ul>
                                <li>Enter Group 1 and Group 2 names.</li>
                                <li>Click Start Game.</li>
                                <li>Roll dice to decide who plays first.</li>
                                <li>On each turn, roll the movement dice first.</li>
                                <li>A question popup appears automatically.</li>
                                <li>Correct answer: gain 1 score and move by the dice value.</li>
                                <li>Wrong answer or timeout: no movement and no score.</li>
                                <li>First player to reach Finish tile 44 wins.</li>
                            </ul>
                        </div>

                        <div>
                            <h4>Multiplayer Play</h4>
                            <ul>
                                <li>Player 1 enters a name and clicks Create Game.</li>
                                <li>Player 2 enters a name and joins using the game code.</li>
                                <li>When both players are ready, start the game.</li>
                                <li>Game start, dice, questions, answers, timer, score, position, reset, and turns are synchronized.</li>
                                <li>Only the current player can answer.</li>
                                <li>The waiting player can view the question in read-only mode.</li>
                                <li>A disconnected player can reconnect using the same game code and player name.</li>
                            </ul>
                        </div>
                    </div>
                </section>
            </div>

            <div class="setup-right-column">
                <section class="multiplayer-setup-panel setup-card">
                    <div class="setup-card-header">
                        <div>
                            <span class="status-label">Online Room</span>
                            <h3>Multiplayer Room</h3>
                        </div>
                        <span class="connection-pill">@multiplayerConnectionStatus</span>
                    </div>

                    <p class="setup-card-description">
                        Create a room or join with a game code. Group names fill in automatically when both players are ready.
                    </p>

                    <div class="setup-form-field">
                        <label for="multiplayerPlayerName" class="form-label">Player Name</label>
                        <input id="multiplayerPlayerName" class="form-control setup-input" @bind="multiplayerPlayerName" />
                    </div>

                    <button class="btn setup-action-button create-game-button" @onclick="CreateMultiplayerGame" disabled="@(!IsMultiplayerConnected)">
                        Create Game
                    </button>

                    @if (!string.IsNullOrWhiteSpace(currentMultiplayerGameCode))
                    {
                        <p class="multiplayer-code">Game Code: <strong>@currentMultiplayerGameCode</strong></p>
                    }

                    <div class="setup-form-field">
                        <label for="joinGameCode" class="form-label">Game Code</label>
                        <input id="joinGameCode" class="form-control setup-input" @bind="joinGameCode" />
                    </div>

                    <button class="btn setup-action-button join-game-button" @onclick="JoinMultiplayerGame" disabled="@(!IsMultiplayerConnected)">
                        Join Game
                    </button>

                    @if (!string.IsNullOrWhiteSpace(multiplayerRoomMessage))
                    {
                        <p class="multiplayer-room-message">@multiplayerRoomMessage</p>
                    }
                </section>

                <section class="local-play-panel setup-card">
                    <div class="setup-card-header">
                        <div>
                            <span class="status-label">Same Screen</span>
                            <h3>Local Play</h3>
                        </div>
                    </div>

                    <p class="setup-card-description">
                        Play with two groups on this computer.
                    </p>

                    <div class="setup-form-field">
                        <label for="group1Name" class="form-label">Group 1</label>
                        <input id="group1Name" class="form-control setup-input" @bind="request.Player1Name" />
                    </div>

                    <div class="setup-form-field">
                        <label for="group2Name" class="form-label">Group 2</label>
                        <input id="group2Name" class="form-control setup-input" @bind="request.Player2Name" />
                    </div>

                    <button class="btn setup-action-button start-game-button" @onclick="StartGame" disabled="@isStarting">
                        Start Game
                    </button>
                </section>
            </div>
        </div>
    </section>
}

@if (IsGameStarted)
{
<div class="game-layout mt-2">
    <main class="game-main">
        <aside class="game-info-panel">
@if (hasWinner && WinnerPlayer is not null)
{
    <section class="winner-banner mt-3">
        <div>
            <span class="winner-label">Game Over</span>
            <h2>@WinnerPlayer.Name wins!</h2>
        </div>

        <div class="winner-stats">
            <div class="winner-stat winner-stat-main">
                <span>Winner</span>
                <strong>@WinnerPlayer.Name</strong>
                <small>Score @WinnerPlayer.Score | Position @WinnerPlayer.Position</small>
            </div>

            @if (OtherPlayer is not null)
            {
                <div class="winner-stat">
                    <span>Other Player</span>
                    <strong>@OtherPlayer.Name</strong>
                    <small>Score @OtherPlayer.Score | Position @OtherPlayer.Position</small>
                </div>
            }
        </div>
    </section>
}

@if (session is not null)
{
    <section class="player-summary">
        <div class="player-summary-card @(currentPlayerName == session.Player1.Name && !hasWinner ? "player-summary-active" : "")">
            <img class="summary-player-image" src="/images/game/run.jpg" alt="Group 1" />
            <span class="status-label">Group 1</span>
            <strong>@session.Player1.Name</strong>
            <span>Score @session.Player1.Score</span>
            <span>Position @session.Player1.Position</span>
        </div>

        <div class="player-summary-card @(currentPlayerName == session.Player2.Name && !hasWinner ? "player-summary-active" : "")">
            <img class="summary-player-image" src="/images/game/run1.jpg" alt="Group 2" />
            <span class="status-label">Group 2</span>
            <strong>@session.Player2.Name</strong>
            <span>Score @session.Player2.Score</span>
            <span>Position @session.Player2.Position</span>
        </div>
    </section>

    @if (IsFirstPlayerDecided && !hasWinner)
    {
        <div class="current-turn-badge">
            Current Turn: @currentPlayerName
        </div>
    }

    @if (!IsFirstPlayerDecided)
    {
        <button class="btn btn-secondary mt-2" @onclick="RollStartDice" disabled="@isRollingDice">
            Roll Dice To Decide First Player
        </button>
    }

    @if (IsFirstPlayerDecided && !hasWinner)
    {
        <p class="compact-note">@diceResult?.FirstPlayerName will play first.</p>
    }
}

<section class="status-panel mt-2">
    <div class="status-item status-main">
        <span class="status-label">Status</span>
        <span>@GameStatusMessage</span>
    </div>

    <div class="status-item">
        <span class="status-label">Turn</span>
        <span>@CurrentTurnDisplay</span>
    </div>

    <div class="status-item">
        <span class="status-label">Group 1 Tile</span>
        <span>@Group1TileColorDisplay</span>
    </div>

    <div class="status-item">
        <span class="status-label">Group 2 Tile</span>
        <span>@Group2TileColorDisplay</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="status-item status-note">
            <span class="status-label">Message</span>
            <span>@message</span>
        </div>
    }
</section>

<section class="multiplayer-panel mt-2">
    <div class="multiplayer-panel-header">
        <span class="status-label">Multiplayer</span>
        <strong>@multiplayerConnectionStatus</strong>
    </div>

    @if (!string.IsNullOrWhiteSpace(multiplayerRoomMessage))
    {
        <p class="multiplayer-room-message">@multiplayerRoomMessage</p>
    }
</section>
        </aside>

        <section class="game-center">
@if (session is not null)
{
    <div class="game-board mt-3">
        @for (var position = 0; position <= 44; position++)
        {
            <div class="board-tile @GetTileCssClass(position)" style="@GetTileGridStyle(position)">
                <div class="tile-number">@position</div>
                <div class="tile-label">@GetTileLabel(position)</div>
                <div class="tile-color">@GetTileColor(position)</div>

                <div class="player-markers">
                    @if (session.Player1.Position == position)
                    {
                        <img class="player-marker @(currentPlayerName == session.Player1.Name && !hasWinner ? "player-marker-current" : "") @(isAnimatingMovement && currentPlayerName == session.Player1.Name ? "player-marker-moving" : "")" src="/images/game/run.jpg" alt="Group 1 marker" title="Group 1" />
                    }

                    @if (session.Player2.Position == position)
                    {
                        <img class="player-marker @(currentPlayerName == session.Player2.Name && !hasWinner ? "player-marker-current" : "") @(isAnimatingMovement && currentPlayerName == session.Player2.Name ? "player-marker-moving" : "")" src="/images/game/run1.jpg" alt="Group 2 marker" title="Group 2" />
                    }
                </div>
            </div>
        }

        <div class="board-center-decoration">
            <span>Finish Zone</span>
        </div>
    </div>
}

        </section>
    </main>

    <aside class="dice-panel">
        <h2>Dice</h2>

        @if (!IsFirstPlayerDecided || isRollingDice)
        {
            <section class="dice-card">
                <span class="dice-card-label">First Player Dice</span>

                @if (isRollingDice)
                {
                    <div class="dice-rolling dice-rolling-large">
                        <div class="dice-results">
                            <div class="dice-result">
                                <img class="dice-image" src="@GetDiceImagePath(rollingPlayer1DiceValue)" alt="Rolling Group 1 dice" />
                                <p>Group 1 rolling...</p>
                            </div>

                            <div class="dice-result">
                                <img class="dice-image" src="@GetDiceImagePath(rollingPlayer2DiceValue)" alt="Rolling Group 2 dice" />
                                <p>Group 2 rolling...</p>
                            </div>
                        </div>
                    </div>
                }
                else if (diceResult is not null)
                {
                    <div class="dice-results">
                        <div class="dice-result">
                            <img class="dice-image" src="@GetDiceImagePath(diceResult.Player1DiceValue)" alt="Group 1 dice" />
                            <p>Group 1: @diceResult.Player1DiceValue</p>
                        </div>

                        <div class="dice-result">
                            <img class="dice-image" src="@GetDiceImagePath(diceResult.Player2DiceValue)" alt="Group 2 dice" />
                            <p>Group 2: @diceResult.Player2DiceValue</p>
                        </div>
                    </div>

                    <p class="dice-message">@diceResult.Message</p>
                }
                else
                {
                    <p class="dice-empty">Roll first-player dice after starting the game.</p>
                }
            </section>
        }

        <section class="dice-card">
            <span class="dice-card-label">Movement Dice</span>

            @if (isRollingMovementDice)
            {
                <div class="dice-rolling dice-rolling-large">
                    <img class="dice-image dice-image-large" src="@GetDiceImagePath(rollingMovementDiceValue)" alt="Rolling movement dice" />
                    <p>Rolling movement dice...</p>
                </div>
            }
            else if (movementDiceValue > 0)
            {
                <div class="movement-dice-final">
                    <img class="dice-image dice-image-large" src="@GetDiceImagePath(movementDiceValue)" alt="Movement dice" />
                    <p>Move @movementDiceValue spaces</p>
                </div>
            }
            else
            {
                <p class="dice-empty">Roll movement dice to open a question.</p>
            }

            @if (CanRollMovementDice)
            {
                <button class="btn roll-movement-button" @onclick="RollMovementDice" disabled="@isRollingMovementDice">
                    Roll Movement Dice
                </button>
            }
            else if (IsMultiplayerGameplay && IsFirstPlayerDecided && !IsCurrentMultiplayerPlayerTurn && question is null && !hasWinner)
            {
                <p class="dice-empty">Waiting for @currentPlayerName to roll.</p>
            }
        </section>
    </aside>
</div>
}

@if (isQuestionModalOpen && question is not null)
{
    <div class="question-modal-backdrop">
        <section class="question-modal" role="dialog" aria-modal="true" aria-labelledby="question-modal-title">
            <div class="question-modal-header">
                <span class="question-section-label">Question Card</span>
                <strong id="question-modal-title">@currentPlayerName</strong>
            </div>

            @if (!string.IsNullOrWhiteSpace(questionTileMessage))
            {
                <p class="question-tile-message">@questionTileMessage</p>
            }

            @if (IsWaitingForMultiplayerAnswer)
            {
                <p class="readonly-question-message">Waiting for @currentPlayerName to answer.</p>
            }

            <div class="question-timer">
                <span>Time remaining</span>
                <strong>@remainingSeconds seconds</strong>
            </div>

            <div class="question-text">
                @question.Text
            </div>

            @if (movementDiceValue == 0 && !isQuestionExpired)
            {
                <p class="submit-hint">Roll the movement dice to open the question popup.</p>
            }

            <div class="answer-options">
                <span class="question-section-label">Answer Options</span>

                @foreach (var option in question.Options)
                {
                    <div class="form-check answer-option">
                        <input class="form-check-input"
                               type="radio"
                               name="questionOption"
                               id="option-@option.Number"
                               value="@option.Number"
                               disabled="@(!CanSelectAnswer)"
                               checked="@(selectedAnswerNumber == option.Number)"
                               @onchange="() => SelectAnswer(option.Number)" />
                        <label class="form-check-label" for="option-@option.Number">
                            @option.Text
                        </label>
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(questionModalMessage))
            {
                <div class="question-modal-result">
                    @questionModalMessage
                </div>
            }

            <div class="question-actions">
                @if (CanSubmitAnswer)
                {
                    <button class="btn btn-primary" @onclick="SubmitAnswer" disabled="@isSubmittingAnswer">
                        Submit Answer
                    </button>
                }
                else if (IsWaitingForMultiplayerAnswer)
                {
                    <span class="submit-hint">Waiting for @currentPlayerName to answer.</span>
                }
                else
                {
                    <span class="submit-hint">Choose an answer to submit.</span>
                }
            </div>
        </section>
    </div>
}

@if (isHowToPlayOpen)
{
    <div class="help-modal-backdrop" @onclick="HideHowToPlay">
        <section class="help-modal" role="dialog" aria-modal="true" aria-labelledby="help-modal-title" @onclick:stopPropagation="true">
            <div class="help-modal-header">
                <h2 id="help-modal-title">How to Play</h2>
                <button class="btn btn-sm btn-outline-secondary" @onclick="HideHowToPlay">
                    Close
                </button>
            </div>

            <h3>Local Play</h3>
            <ul>
                <li>Enter Group 1 and Group 2 names, then click Start Game.</li>
                <li>Roll dice to decide who plays first.</li>
                <li>On each turn, roll the movement dice first. A question popup appears automatically.</li>
                <li>Answer before the timer reaches 0.</li>
                <li>Correct answer: gain 1 score and move forward by the dice value.</li>
                <li>Wrong answer or timeout: no movement and no score.</li>
                <li>The first player to reach the Finish tile wins.</li>
            </ul>

            <h3>Multiplayer Play</h3>
            <ul>
                <li>Player 1 enters a name and clicks Create Game.</li>
                <li>Player 2 enters a name and joins using the game code.</li>
                <li>When both players are ready, start the game.</li>
                <li>Game start, dice rolls, questions, answers, score, position, timer, reset, and turns are synchronized.</li>
                <li>Only the current player can roll and answer during their turn.</li>
                <li>If a player disconnects, they can reconnect using the same game code and player name.</li>
            </ul>
        </section>
    </div>
}

@code {
    private readonly StartGameRequest request = new();
    private GameSessionDto? session;
    private RollDiceResultDto? diceResult;
    private QuestionDto? question;
    private SubmitAnswerResultDto? answerResult;
    private HubConnection? hubConnection;
    private string? message;
    private string? currentPlayerName;
    private string? tileMessage;
    private string? questionTileMessage;
    private string? questionModalMessage;
    private string multiplayerConnectionStatus = "Disconnected";
    private string multiplayerRoomStatus = "Not connected";
    private string multiplayerPlayerName = string.Empty;
    private string joinGameCode = string.Empty;
    private string currentMultiplayerGameCode = string.Empty;
    private string multiplayerRoomMessage = string.Empty;
    private readonly List<int> usedQuestionIds = new();
    private int selectedAnswerNumber;
    private int movementDiceValue;
    private int rollingPlayer1DiceValue = 1;
    private int rollingPlayer2DiceValue = 1;
    private int rollingMovementDiceValue = 1;
    private int remainingSeconds;
    private int questionTimeLimitSeconds = 30;
    private bool hasWinner;
    private bool hasSubmittedCurrentQuestion;
    private bool isStarting;
    private bool isRollingDice;
    private bool isRollingMovementDice;
    private bool isLoadingQuestion;
    private bool isSubmittingAnswer;
    private bool isQuestionExpired;
    private bool isQuestionModalOpen;
    private bool isAnimatingMovement;
    private bool isSoundOn = true;
    private bool isHowToPlayOpen;
    private DateTime? questionStartedAtUtc;
    private CancellationTokenSource? countdownCancellation;

    private bool IsGameStarted => session is not null;

    private bool IsMultiplayerConnected => hubConnection?.State == HubConnectionState.Connected;

    private bool IsMultiplayerRoomReady => IsMultiplayerConnected &&
        !string.IsNullOrWhiteSpace(currentMultiplayerGameCode) &&
        (multiplayerRoomStatus == "Game ready" || multiplayerRoomStatus == "Game started");

    private bool ShouldStartMultiplayerGame => IsMultiplayerConnected &&
        !string.IsNullOrWhiteSpace(currentMultiplayerGameCode) &&
        multiplayerRoomStatus == "Game ready";

    private bool ShouldRollMultiplayerFirstDice => IsMultiplayerRoomReady && IsGameStarted;

    private bool IsMultiplayerGameplay => IsMultiplayerRoomReady && IsGameStarted;

    private bool IsCurrentMultiplayerPlayerTurn => !IsMultiplayerGameplay ||
        (!string.IsNullOrWhiteSpace(multiplayerPlayerName) &&
         string.Equals(multiplayerPlayerName.Trim(), currentPlayerName, StringComparison.OrdinalIgnoreCase));

    private bool IsFirstPlayerDecided => !string.IsNullOrWhiteSpace(currentPlayerName) && diceResult?.IsDraw == false;

    private bool CanRollMovementDice => IsGameStarted && IsFirstPlayerDecided && IsCurrentMultiplayerPlayerTurn && question is null && movementDiceValue == 0 && !isLoadingQuestion && !isQuestionModalOpen && !isRollingMovementDice && !isAnimatingMovement && !hasWinner;

    private bool CanSelectAnswer => question is not null && isQuestionModalOpen && IsCurrentMultiplayerPlayerTurn && !isQuestionExpired && !isSubmittingAnswer && !hasSubmittedCurrentQuestion && !hasWinner;

    private bool CanSubmitAnswer => question is not null && isQuestionModalOpen && IsCurrentMultiplayerPlayerTurn && movementDiceValue > 0 && selectedAnswerNumber > 0 && !isRollingMovementDice && !isAnimatingMovement && !isSubmittingAnswer && !isQuestionExpired && remainingSeconds > 0 && !hasWinner && !hasSubmittedCurrentQuestion;

    private bool IsWaitingForMultiplayerAnswer => IsMultiplayerGameplay && question is not null && isQuestionModalOpen && !IsCurrentMultiplayerPlayerTurn && !hasWinner;

    private PlayerDto? WinnerPlayer
    {
        get
        {
            if (!hasWinner || session is null)
            {
                return null;
            }

            if (session.Player1.Position >= 44)
            {
                return session.Player1;
            }

            if (session.Player2.Position >= 44)
            {
                return session.Player2;
            }

            return GetCurrentPlayer();
        }
    }

    private PlayerDto? OtherPlayer
    {
        get
        {
            if (session is null || WinnerPlayer is null)
            {
                return null;
            }

            return WinnerPlayer.Name == session.Player1.Name
                ? session.Player2
                : session.Player1;
        }
    }

    private string GameStatusMessage
    {
        get
        {
            if (!IsGameStarted)
            {
                return "Enter group names to start.";
            }

            if (hasWinner)
            {
                return $"Game over. {currentPlayerName} wins.";
            }

            if (isAnimatingMovement)
            {
                return $"{currentPlayerName} is moving on the board.";
            }

            if (!IsFirstPlayerDecided)
            {
                return "Roll dice to decide first player.";
            }

            if (question is not null)
            {
                if (IsMultiplayerGameplay && !IsCurrentMultiplayerPlayerTurn)
                {
                    return $"Waiting for {currentPlayerName} to answer.";
                }

                return "Answer the question before time runs out.";
            }

            if (IsMultiplayerGameplay && !IsCurrentMultiplayerPlayerTurn)
            {
                return $"Waiting for {currentPlayerName} to roll.";
            }

            return $"It is {currentPlayerName}'s turn. Roll the movement dice.";
        }
    }

    private string CurrentTurnDisplay
    {
        get
        {
            if (hasWinner)
            {
                return "Game over";
            }

            return string.IsNullOrWhiteSpace(currentPlayerName) ? "Not decided" : currentPlayerName;
        }
    }

    private string Group1TileColorDisplay => session is null ? "Not started" : GetTileColorName(session.Player1.Position);

    private string Group2TileColorDisplay => session is null ? "Not started" : GetTileColorName(session.Player2.Position);

    protected override async Task OnInitializedAsync()
    {
        await ConnectToGameHub();
    }

    private async Task ConnectToGameHub()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl("http://localhost:5073/gamehub")
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string>("GameCreated", async gameCode =>
        {
            currentMultiplayerGameCode = gameCode;
            joinGameCode = gameCode;
            multiplayerRoomMessage = "Share this game code with Player 2.";
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<string>("MultiplayerStatus", async status =>
        {
            multiplayerRoomStatus = status;
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<string, string, string>("GameReady", async (gameCode, player1Name, player2Name) =>
        {
            currentMultiplayerGameCode = gameCode;
            joinGameCode = gameCode;
            multiplayerRoomStatus = "Game ready";
            multiplayerRoomMessage = "Both players joined. You can start the game when ready.";
            request.Player1Name = player1Name;
            request.Player2Name = player2Name;
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<string, string, string, int, int, int, int>(
            "MultiplayerGameStarted",
            async (gameCode, player1Name, player2Name, player1Score, player2Score, player1Position, player2Position) =>
            {
                currentMultiplayerGameCode = gameCode;
                joinGameCode = gameCode;
                multiplayerRoomStatus = "Game started";
                multiplayerRoomMessage = "Multiplayer game started. Roll dice to decide who plays first.";
                request.Player1Name = player1Name;
                request.Player2Name = player2Name;

                ClearStateForNewGame();

                session = new GameSessionDto
                {
                    Player1 = new PlayerDto
                    {
                        Name = player1Name,
                        Score = player1Score,
                        Position = player1Position
                    },
                    Player2 = new PlayerDto
                    {
                        Name = player2Name,
                        Score = player2Score,
                        Position = player2Position
                    },
                    Message = "The multiplayer game has started."
                };

                message = session.Message;
                isStarting = false;
                await PlaySound("start");
                await InvokeAsync(StateHasChanged);
            });

        hubConnection.On<string, int, int, string, string, bool, string>(
            "MultiplayerFirstDiceRolled",
            async (gameCode, player1DiceValue, player2DiceValue, firstPlayerName, currentTurnPlayerName, isDraw, rollMessage) =>
            {
                currentMultiplayerGameCode = gameCode;
                joinGameCode = gameCode;
                rollingPlayer1DiceValue = player1DiceValue;
                rollingPlayer2DiceValue = player2DiceValue;
                diceResult = new RollDiceResultDto
                {
                    Player1DiceValue = player1DiceValue,
                    Player2DiceValue = player2DiceValue,
                    FirstPlayerName = firstPlayerName,
                    IsDraw = isDraw,
                    Message = rollMessage
                };

                currentPlayerName = isDraw ? null : currentTurnPlayerName;
                tileMessage = currentPlayerName is null ? null : $"{currentPlayerName} is on {GetCurrentPlayerTileColorName()} tile";
                message = isDraw ? rollMessage : null;
                isRollingDice = false;
                await InvokeAsync(StateHasChanged);
            });

        hubConnection.On<string, string, int>(
            "MultiplayerMovementDiceRolled",
            async (gameCode, turnPlayerName, diceValue) =>
            {
                currentMultiplayerGameCode = gameCode;
                currentPlayerName = turnPlayerName;
                movementDiceValue = diceValue;
                rollingMovementDiceValue = diceValue;
                isRollingMovementDice = false;
                await InvokeAsync(StateHasChanged);
            });

        hubConnection.On<string, string, int, QuestionDto, DateTime, int>(
            "MultiplayerQuestionLoaded",
            async (gameCode, turnPlayerName, diceValue, loadedQuestion, questionStartedAt, timeLimitSeconds) =>
            {
                currentMultiplayerGameCode = gameCode;
                currentPlayerName = turnPlayerName;
                movementDiceValue = diceValue;
                rollingMovementDiceValue = diceValue;
                question = loadedQuestion;
                if (!usedQuestionIds.Contains(loadedQuestion.QuestionId))
                {
                    usedQuestionIds.Add(loadedQuestion.QuestionId);
                }

                answerResult = null;
                selectedAnswerNumber = 0;
                questionStartedAtUtc = DateTime.SpecifyKind(questionStartedAt, DateTimeKind.Utc);
                questionTimeLimitSeconds = timeLimitSeconds;
                remainingSeconds = GetServerBasedRemainingSeconds();
                isQuestionExpired = false;
                hasSubmittedCurrentQuestion = false;
                questionTileMessage = $"Question loaded for {GetCurrentPlayerTileColorName()} tile";
                questionModalMessage = null;
                isQuestionModalOpen = true;
                isLoadingQuestion = false;
                StopCountdown();
                StartCountdown();

                await InvokeAsync(StateHasChanged);
            });

        hubConnection.On<string, string, SubmitAnswerResultDto>(
            "MultiplayerAnswerSubmitted",
            async (gameCode, answeringPlayerName, result) =>
            {
                currentMultiplayerGameCode = gameCode;
                answerResult = result;
                questionModalMessage = result.Message;
                message = $"{answeringPlayerName}: {result.Message}";
                isSubmittingAnswer = false;
                hasSubmittedCurrentQuestion = true;
                StopCountdown();
                await PlaySound(result.Message == "Time is up" ? "timeUp" : result.IsCorrect ? "correct" : "wrong");
                await InvokeAsync(StateHasChanged);
            });

        hubConnection.On<string, int, int, int, int, string, string>(
            "MultiplayerGameStateUpdated",
            async (gameCode, player1Score, player2Score, player1Position, player2Position, nextTurnPlayerName, winnerName) =>
            {
                currentMultiplayerGameCode = gameCode;
                await ApplyMultiplayerGameState(
                    player1Score,
                    player2Score,
                    player1Position,
                    player2Position,
                    nextTurnPlayerName,
                    winnerName);
            });

        hubConnection.On<string, string, string, int, int, int, int>(
            "MultiplayerGameReset",
            async (gameCode, player1Name, player2Name, player1Score, player2Score, player1Position, player2Position) =>
            {
                currentMultiplayerGameCode = gameCode;
                joinGameCode = gameCode;
                multiplayerRoomStatus = "Game ready";
                multiplayerRoomMessage = "Multiplayer game reset. You can start again when ready.";
                request.Player1Name = player1Name;
                request.Player2Name = player2Name;
                ClearStateForNewGame();
                message = null;
                isHowToPlayOpen = false;
                await InvokeAsync(StateHasChanged);
            });

        hubConnection.On<string, string, string>(
            "MultiplayerPlayerDisconnected",
            async (gameCode, playerName, disconnectMessage) =>
            {
                currentMultiplayerGameCode = gameCode;
                multiplayerRoomMessage = disconnectMessage;
                await InvokeAsync(StateHasChanged);
            });

        hubConnection.On<string, string, string>(
            "MultiplayerPlayerReconnected",
            async (gameCode, playerName, reconnectMessage) =>
            {
                currentMultiplayerGameCode = gameCode;
                multiplayerRoomMessage = reconnectMessage;
                await InvokeAsync(StateHasChanged);
            });

        hubConnection.On<MultiplayerSessionStateDto>(
            "MultiplayerSessionRestored",
            async restoredState =>
            {
                RestoreMultiplayerSession(restoredState);
                await InvokeAsync(StateHasChanged);
            });

        hubConnection.On<string>("MultiplayerError", async errorMessage =>
        {
            multiplayerRoomMessage = errorMessage;
            isStarting = false;
            isRollingDice = false;
            isRollingMovementDice = false;
            isSubmittingAnswer = false;
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.Reconnecting += error =>
        {
            multiplayerConnectionStatus = "Disconnected";
            multiplayerRoomStatus = "Not connected";
            return InvokeAsync(StateHasChanged);
        };

        hubConnection.Reconnected += connectionId =>
        {
            multiplayerConnectionStatus = "Connected";
            multiplayerRoomStatus = string.IsNullOrWhiteSpace(currentMultiplayerGameCode) ? "Not connected" : multiplayerRoomStatus;
            return InvokeAsync(async () =>
            {
                if (!string.IsNullOrWhiteSpace(currentMultiplayerGameCode) &&
                    !string.IsNullOrWhiteSpace(multiplayerPlayerName) &&
                    hubConnection is not null)
                {
                    await hubConnection.InvokeAsync("JoinGame", currentMultiplayerGameCode, multiplayerPlayerName);
                }

                StateHasChanged();
            });
        };

        hubConnection.Closed += error =>
        {
            multiplayerConnectionStatus = "Disconnected";
            multiplayerRoomStatus = "Not connected";
            return InvokeAsync(StateHasChanged);
        };

        try
        {
            await hubConnection.StartAsync();
            multiplayerConnectionStatus = "Connected";
            multiplayerRoomStatus = "Not connected";
        }
        catch
        {
            multiplayerConnectionStatus = "Disconnected";
            multiplayerRoomStatus = "Not connected";
        }
    }

