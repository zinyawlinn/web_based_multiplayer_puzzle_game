    private async Task StartGame()
    {
        if (string.IsNullOrWhiteSpace(request.Player1Name) || string.IsNullOrWhiteSpace(request.Player2Name))
        {
            message = "Please enter names for both groups.";
            session = null;
            return;
        }

        if (ShouldStartMultiplayerGame)
        {
            await StartMultiplayerGame();
            return;
        }

        isStarting = true;
        ClearStateForNewGame();

        try
        {
            var response = await Http.PostAsJsonAsync("http://localhost:5073/api/game/start", request);

            if (response.IsSuccessStatusCode)
            {
                session = await response.Content.ReadFromJsonAsync<GameSessionDto>();
                message = session?.Message ?? "The game has started.";
                await PlaySound("start");
            }
            else
            {
                message = await response.Content.ReadAsStringAsync();
            }
        }
        catch
        {
            message = "Could not start the game. Make sure the API is running.";
        }
        finally
        {
            isStarting = false;
        }
    }

