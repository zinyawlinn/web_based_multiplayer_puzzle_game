    private async Task RollStartDice()
    {
        if (session is null)
        {
            message = "Please start the game first.";
            return;
        }

        isRollingDice = true;
        diceResult = null;
        question = null;
        answerResult = null;
        tileMessage = null;
        questionTileMessage = null;
        questionModalMessage = null;
        selectedAnswerNumber = 0;
        movementDiceValue = 0;
        rollingPlayer1DiceValue = 1;
        rollingPlayer2DiceValue = 1;
        rollingMovementDiceValue = 1;
        remainingSeconds = 0;
        questionStartedAtUtc = null;
        questionTimeLimitSeconds = 30;
        isQuestionExpired = false;
        hasSubmittedCurrentQuestion = false;
        isRollingMovementDice = false;
        isQuestionModalOpen = false;
        StopCountdown();
        await PlaySound("dice");
        await AnimateStartDiceFaces();

        if (session is null)
        {
            isRollingDice = false;
            return;
        }

        if (ShouldRollMultiplayerFirstDice && hubConnection is not null)
        {
            try
            {
                await hubConnection.InvokeAsync("RollFirstPlayerDice", currentMultiplayerGameCode);
            }
            catch
            {
                isRollingDice = false;
                multiplayerRoomMessage = "Could not roll multiplayer first-player dice.";
            }

            return;
        }

        var rollRequest = new RollDiceRequest
        {
            Player1Name = session.Player1.Name,
            Player2Name = session.Player2.Name
        };

        try
        {
            var response = await Http.PostAsJsonAsync("http://localhost:5073/api/game/roll-start-dice", rollRequest);

            if (response.IsSuccessStatusCode)
            {
                diceResult = await response.Content.ReadFromJsonAsync<RollDiceResultDto>();
                rollingPlayer1DiceValue = diceResult?.Player1DiceValue ?? rollingPlayer1DiceValue;
                rollingPlayer2DiceValue = diceResult?.Player2DiceValue ?? rollingPlayer2DiceValue;
                currentPlayerName = diceResult?.IsDraw == false ? diceResult.FirstPlayerName : null;
                tileMessage = currentPlayerName is null ? null : $"{currentPlayerName} is on {GetCurrentPlayerTileColorName()} tile";
                message = null;
            }
            else
            {
                message = await response.Content.ReadAsStringAsync();
            }
        }
        catch
        {
            message = "Could not roll the dice. Make sure the API is running.";
        }
        finally
        {
            isRollingDice = false;
        }
    }

    private async Task<bool> LoadQuestion()
    {
        var questionLoaded = false;
        isLoadingQuestion = true;
        question = null;
        answerResult = null;
        questionTileMessage = null;
        questionModalMessage = null;
        selectedAnswerNumber = 0;
        remainingSeconds = 30;
        questionStartedAtUtc = null;
        questionTimeLimitSeconds = 30;
        isQuestionExpired = false;
        hasSubmittedCurrentQuestion = false;
        isRollingMovementDice = false;
        isQuestionModalOpen = false;
        StopCountdown();

        try
        {
            var loadQuestionRequest = new LoadQuestionRequest
            {
                UsedQuestionIds = usedQuestionIds
            };

            var response = await Http.PostAsJsonAsync("http://localhost:5073/api/game/question", loadQuestionRequest);

            if (response.IsSuccessStatusCode)
            {
                question = await response.Content.ReadFromJsonAsync<QuestionDto>();

                if (question is not null)
                {
                    usedQuestionIds.Add(question.QuestionId);
                    questionTileMessage = $"Question loaded for {GetCurrentPlayerTileColorName()} tile";
                    isQuestionModalOpen = true;
                    questionLoaded = true;
                    message = null;
                    StartCountdown();
                }
            }
            else
            {
                message = await response.Content.ReadAsStringAsync();
                remainingSeconds = 0;
            }
        }
        catch
        {
            message = "Could not load a question. Make sure the API is running.";
            remainingSeconds = 0;
        }
        finally
        {
            isLoadingQuestion = false;
        }

        return questionLoaded;
    }

