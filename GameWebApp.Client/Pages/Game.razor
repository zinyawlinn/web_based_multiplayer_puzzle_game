    private async Task RollMovementDice()
    {
        if (!CanRollMovementDice)
        {
            return;
        }

        isRollingMovementDice = true;
        movementDiceValue = 0;
        rollingMovementDiceValue = 1;
        await PlaySound("dice");
        await AnimateMovementDiceFace();

        if (session is null || hasWinner)
        {
            isRollingMovementDice = false;
            return;
        }

        if (IsMultiplayerGameplay && hubConnection is not null)
        {
            try
            {
                await hubConnection.InvokeAsync("RollMultiplayerMovementDice", currentMultiplayerGameCode);
            }
            catch
            {
                isRollingMovementDice = false;
                multiplayerRoomMessage = "Could not roll multiplayer movement dice.";
            }

            return;
        }

        movementDiceValue = Random.Shared.Next(1, 7);
        rollingMovementDiceValue = movementDiceValue;
        isRollingMovementDice = false;
        questionModalMessage = null;
        await InvokeAsync(StateHasChanged);

        var questionLoaded = await LoadQuestion();

        if (!questionLoaded)
        {
            movementDiceValue = 0;
            rollingMovementDiceValue = 1;
        }
    }

    private async Task AnimateStartDiceFaces()
    {
        for (var rollStep = 0; rollStep < 8 && isRollingDice; rollStep++)
        {
            rollingPlayer1DiceValue = Random.Shared.Next(1, 7);
            rollingPlayer2DiceValue = Random.Shared.Next(1, 7);
            await InvokeAsync(StateHasChanged);
            await Task.Delay(125);
        }
    }

    private async Task AnimateMovementDiceFace()
    {
        for (var rollStep = 0; rollStep < 8 && isRollingMovementDice; rollStep++)
        {
            rollingMovementDiceValue = Random.Shared.Next(1, 7);
            await InvokeAsync(StateHasChanged);
            await Task.Delay(125);
        }
    }

    private async Task SubmitAnswer()
    {
        if (hasSubmittedCurrentQuestion)
        {
            message = "This question has already been submitted.";
            return;
        }

        if (question is null)
        {
            message = "Please load a question first.";
            return;
        }

        if (isQuestionExpired || remainingSeconds <= 0)
        {
            questionModalMessage = "Time is up";
            return;
        }

        if (selectedAnswerNumber == 0)
        {
            questionModalMessage = "Please select an answer.";
            return;
        }

        if (IsMultiplayerGameplay)
        {
            await SubmitMultiplayerAnswer();
            return;
        }

        StopCountdown();

        var currentPlayer = GetCurrentPlayer();

        if (currentPlayer is null)
        {
            message = "Please roll dice to decide the first player.";
            return;
        }

        isSubmittingAnswer = true;
        hasSubmittedCurrentQuestion = true;
        message = null;
        answerResult = null;

        var submitRequest = new SubmitAnswerRequest
        {
            QuestionId = question.QuestionId,
            SelectedAnswerNumber = selectedAnswerNumber,
            CurrentPlayerName = currentPlayer.Name,
            CurrentPlayerPosition = currentPlayer.Position,
            CurrentPlayerScore = currentPlayer.Score,
            MovementDiceValue = movementDiceValue
        };

        try
        {
            var response = await Http.PostAsJsonAsync("http://localhost:5073/api/game/submit-answer", submitRequest);

            if (response.IsSuccessStatusCode)
            {
                answerResult = await response.Content.ReadFromJsonAsync<SubmitAnswerResultDto>();

                if (answerResult is not null)
                {
                    var startPosition = currentPlayer.Position;
                    var finalPosition = answerResult.UpdatedPosition;
                    var isWinner = answerResult.IsWinner;

                    currentPlayer.Score = answerResult.UpdatedScore;
                    questionModalMessage = answerResult.Message;
                    await PlaySound(answerResult.IsCorrect ? "correct" : "wrong");
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(1000);
                    ClearCurrentQuestion();

                    if (answerResult.IsCorrect && finalPosition > startPosition)
                    {
                        await AnimatePlayerMovement(currentPlayer, startPosition, finalPosition);
                    }
                    else
                    {
                        currentPlayer.Position = finalPosition;
                    }

                    hasWinner = isWinner;
                    tileMessage = $"{currentPlayer.Name} is on {GetTileColorName(currentPlayer.Position)} tile";

                    if (hasWinner)
                    {
                        await PlaySound("winner");
                    }

                    if (!hasWinner)
                    {
                        SwitchTurn();
                    }
                }
            }
            else
            {
                questionModalMessage = await response.Content.ReadAsStringAsync();
            }
        }
        catch
        {
            questionModalMessage = "Could not submit the answer. Make sure the API is running.";
        }
        finally
        {
            isSubmittingAnswer = false;
        }
    }

    private async Task SubmitMultiplayerAnswer()
    {
        if (!IsMultiplayerConnected || hubConnection is null)
        {
            multiplayerRoomMessage = "Multiplayer is disconnected. Start the API and refresh the page.";
            return;
        }

        if (question is null)
        {
            questionModalMessage = "Please load a question first.";
            return;
        }

        StopCountdown();
        isSubmittingAnswer = true;
        hasSubmittedCurrentQuestion = true;
        message = null;
        answerResult = null;

        try
        {
            await hubConnection.InvokeAsync(
                "SubmitMultiplayerAnswer",
                currentMultiplayerGameCode,
                question.QuestionId,
                selectedAnswerNumber);
        }
        catch
        {
            isSubmittingAnswer = false;
            hasSubmittedCurrentQuestion = false;
            questionModalMessage = "Could not submit the multiplayer answer.";
        }
    }

    private async Task ApplyMultiplayerGameState(
        int player1Score,
        int player2Score,
        int player1Position,
        int player2Position,
        string nextTurnPlayerName,
        string winnerName)
    {
        if (session is null)
        {
            return;
        }

        var movingPlayerName = currentPlayerName;
        var player1StartPosition = session.Player1.Position;
        var player2StartPosition = session.Player2.Position;

        session.Player1.Score = player1Score;
        session.Player2.Score = player2Score;

        await Task.Delay(1000);
        ClearCurrentQuestion();

        if (movingPlayerName == session.Player1.Name && player1Position > player1StartPosition)
        {
            await AnimatePlayerMovement(session.Player1, player1StartPosition, player1Position);
        }
        else
        {
            session.Player1.Position = player1Position;
        }

        if (movingPlayerName == session.Player2.Name && player2Position > player2StartPosition)
        {
            await AnimatePlayerMovement(session.Player2, player2StartPosition, player2Position);
        }
        else
        {
            session.Player2.Position = player2Position;
        }

        hasWinner = !string.IsNullOrWhiteSpace(winnerName);
        currentPlayerName = hasWinner ? winnerName : nextTurnPlayerName;

        var movedPlayer = movingPlayerName == session.Player1.Name ? session.Player1 : session.Player2;
        tileMessage = $"{movedPlayer.Name} is on {GetTileColorName(movedPlayer.Position)} tile";

        if (hasWinner)
        {
            await PlaySound("winner");
        }

        await InvokeAsync(StateHasChanged);
    }

    private void RestoreMultiplayerSession(MultiplayerSessionStateDto restoredState)
    {
        StopCountdown();
        ClearStateForNewGame();

        currentMultiplayerGameCode = restoredState.GameCode;
        joinGameCode = restoredState.GameCode;
        request.Player1Name = restoredState.Player1Name;
        request.Player2Name = restoredState.Player2Name;
        multiplayerRoomStatus = restoredState.IsGameStarted ? "Game started" : "Game ready";
        multiplayerRoomMessage = "Multiplayer session restored.";

        if (!restoredState.IsGameStarted)
        {
            return;
        }

        session = new GameSessionDto
        {
            Player1 = new PlayerDto
            {
                Name = restoredState.Player1Name,
                Score = restoredState.Player1Score,
                Position = restoredState.Player1Position
            },
            Player2 = new PlayerDto
            {
                Name = restoredState.Player2Name,
                Score = restoredState.Player2Score,
                Position = restoredState.Player2Position
            },
            Message = "The multiplayer game has been restored."
        };

        if (restoredState.Player1FirstDiceValue > 0 && restoredState.Player2FirstDiceValue > 0)
        {
            diceResult = new RollDiceResultDto
            {
                Player1DiceValue = restoredState.Player1FirstDiceValue,
                Player2DiceValue = restoredState.Player2FirstDiceValue,
                FirstPlayerName = restoredState.FirstPlayerName,
                IsDraw = string.IsNullOrWhiteSpace(restoredState.FirstPlayerName),
                Message = string.IsNullOrWhiteSpace(restoredState.FirstPlayerName)
                    ? "The dice values are the same. Please roll again."
                    : $"{restoredState.FirstPlayerName} will play first."
            };
        }

        currentPlayerName = string.IsNullOrWhiteSpace(restoredState.WinnerName)
            ? restoredState.CurrentTurnPlayerName
            : restoredState.WinnerName;
        movementDiceValue = restoredState.CurrentMovementDiceValue;
        rollingMovementDiceValue = movementDiceValue > 0 ? movementDiceValue : 1;
        hasWinner = !string.IsNullOrWhiteSpace(restoredState.WinnerName);

        if (restoredState.IsQuestionActive && restoredState.CurrentQuestion is not null)
        {
            question = restoredState.CurrentQuestion;
            questionStartedAtUtc = DateTime.SpecifyKind(restoredState.QuestionStartedAt, DateTimeKind.Utc);
            questionTimeLimitSeconds = restoredState.QuestionTimeLimitSeconds;
            remainingSeconds = GetServerBasedRemainingSeconds();
            questionTileMessage = $"Question loaded for {GetCurrentPlayerTileColorName()} tile";
            questionModalMessage = null;
            isQuestionModalOpen = true;
            StartCountdown();
        }

        if (hasWinner)
        {
            message = $"Game over. {restoredState.WinnerName} wins.";
        }
    }

    private void StartCountdown()
    {
        countdownCancellation = new CancellationTokenSource();
        _ = RunCountdownAsync(countdownCancellation.Token);
    }

    private void StopCountdown()
    {
        countdownCancellation?.Cancel();
        countdownCancellation?.Dispose();
        countdownCancellation = null;
    }

    private async Task RunCountdownAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                if (IsMultiplayerGameplay && questionStartedAtUtc.HasValue)
                {
                    remainingSeconds = GetServerBasedRemainingSeconds();
                }

                if (remainingSeconds <= 0)
                {
                    break;
                }

                await InvokeAsync(StateHasChanged);
                await Task.Delay(1000, cancellationToken);

                if (!IsMultiplayerGameplay || !questionStartedAtUtc.HasValue)
                {
                    remainingSeconds--;
                }
            }

            if (IsMultiplayerGameplay && questionStartedAtUtc.HasValue)
            {
                remainingSeconds = GetServerBasedRemainingSeconds();
                await InvokeAsync(StateHasChanged);
            }

            if (!cancellationToken.IsCancellationRequested && question is not null && !hasSubmittedCurrentQuestion && !hasWinner)
            {
                isQuestionExpired = true;
                message = "Time is up";
                questionModalMessage = "Time is up";
                await InvokeAsync(StateHasChanged);
                await Task.Delay(1000, cancellationToken);

                if (IsMultiplayerGameplay)
                {
                    await SubmitMultiplayerTimeout();
                    return;
                }

                await PlaySound("timeUp");
                questionTileMessage = null;
                SwitchTurn();
                tileMessage = currentPlayerName is null ? null : $"{currentPlayerName} is on {GetCurrentPlayerTileColorName()} tile";
                ClearCurrentQuestion();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (TaskCanceledException)
        {
        }
    }

    private int GetServerBasedRemainingSeconds()
    {
        if (!questionStartedAtUtc.HasValue)
        {
            return remainingSeconds;
        }

        var elapsedSeconds = (int)Math.Floor((DateTime.UtcNow - questionStartedAtUtc.Value).TotalSeconds);
        return Math.Max(0, questionTimeLimitSeconds - elapsedSeconds);
    }

    private async Task SubmitMultiplayerTimeout()
    {
        if (!IsMultiplayerConnected || hubConnection is null || question is null)
        {
            return;
        }

        hasSubmittedCurrentQuestion = true;
        isSubmittingAnswer = true;

        try
        {
            await hubConnection.InvokeAsync(
                "MultiplayerQuestionTimedOut",
                currentMultiplayerGameCode,
                question.QuestionId);
        }
        catch
        {
            isSubmittingAnswer = false;
            questionModalMessage = "Time is up. Could not sync the timeout.";
        }
    }

    private PlayerDto? GetCurrentPlayer()
    {
        if (session is null || string.IsNullOrWhiteSpace(currentPlayerName))
        {
            return null;
        }

        if (session.Player1.Name == currentPlayerName)
        {
            return session.Player1;
        }

        if (session.Player2.Name == currentPlayerName)
        {
            return session.Player2;
        }

        return null;
    }

    private void SwitchTurn()
    {
        if (session is null)
        {
            return;
        }

        currentPlayerName = currentPlayerName == session.Player1.Name
            ? session.Player2.Name
            : session.Player1.Name;
    }

    private async Task AnimatePlayerMovement(PlayerDto player, int startPosition, int finalPosition)
    {
        isAnimatingMovement = true;

        try
        {
            for (var position = startPosition + 1; position <= finalPosition; position++)
            {
                player.Position = position;
                tileMessage = $"{player.Name} is on {GetTileColorName(player.Position)} tile";
                await PlaySound("move");
                await InvokeAsync(StateHasChanged);
                await Task.Delay(250);
            }
        }
        finally
        {
            isAnimatingMovement = false;
        }
    }

    private void ClearCurrentQuestion()
    {
        question = null;
        questionTileMessage = null;
        questionModalMessage = null;
        selectedAnswerNumber = 0;
        movementDiceValue = 0;
        rollingMovementDiceValue = 1;
        remainingSeconds = 0;
        isQuestionExpired = false;
        hasSubmittedCurrentQuestion = false;
        isRollingMovementDice = false;
        isQuestionModalOpen = false;
    }

    private static string GetDiceImagePath(int diceValue)
    {
        return $"/images/game/image{diceValue}.jpg";
    }

    private static CardColor GetTileColor(int position)
    {
        return (position % 3) switch
        {
            0 => CardColor.Red,
            1 => CardColor.Green,
            _ => CardColor.Yellow
        };
    }

    private static string GetTileColorName(int position)
    {
        return GetTileColor(position).ToString();
    }

    private string GetCurrentPlayerTileColorName()
    {
        var currentPlayer = GetCurrentPlayer();
        return currentPlayer is null ? "Red" : GetTileColorName(currentPlayer.Position);
    }

    private string GetTileCssClass(int position)
    {
        var cssClass = GetTileColor(position) switch
        {
            CardColor.Red => "tile-red",
            CardColor.Green => "tile-green",
            _ => "tile-yellow"
        };

        if (hasWinner && position == 44)
        {
            cssClass += " tile-finish-winner";
        }

        var currentPlayer = GetCurrentPlayer();

        if (!hasWinner && currentPlayer is not null && currentPlayer.Position == position)
        {
            cssClass += isAnimatingMovement ? " tile-current-player tile-moving-player" : " tile-current-player";
        }

        return cssClass;
    }

    private static string GetTileGridStyle(int position)
    {
        var (row, column) = GetTileGridPosition(position);
        return $"grid-row: {row}; grid-column: {column};";
    }

    private static (int Row, int Column) GetTileGridPosition(int position)
    {
        return position switch
        {
            <= 6 => (7, position + 1),
            <= 12 => (13 - position, 7),
            <= 18 => (1, 19 - position),
            <= 23 => (position - 17, 1),
            <= 28 => (6, position - 22),
            <= 32 => (34 - position, 6),
            <= 36 => (2, 38 - position),
            <= 39 => (position - 34, 2),
            <= 42 => (5, position - 37),
            43 => (4, 5),
            44 => (4, 4),
            _ => (7, 1)
        };
    }

    private static string GetTileLabel(int position)
    {
        return position switch
        {
            0 => "Start",
            44 => "Finish",
            _ => string.Empty
        };
    }

    public void Dispose()
    {
        StopCountdown();
    }

    public async ValueTask DisposeAsync()
    {
        StopCountdown();

        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}

